# Application
PROJECT_NAME=Devgiri Forgings
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://docvault:docvault_secret@localhost:5432/docvault

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# SMTP Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Devgiri Forgings
SMTP_USE_TLS=true
